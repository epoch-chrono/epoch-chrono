---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../components/layout/BaseLayout.astro';

const entry = await getEntry('now', 'index');
if (!entry) throw new Error('now/index.md not found');
const { Content } = await render(entry);
---

<BaseLayout
  title="now — epoch-chrono"
  description="O que estou fazendo agora."
>
  <article class="space-y-8">
    <header class="space-y-1">
      <h1 class="text-2xl font-semibold tracking-tight text-[#e8edf7]">now</h1>
      <p class="font-mono text-xs text-[#4a607f]">
        atualizado em {entry.data.updatedAt}
      </p>
    </header>

    <div class="prose prose-invert prose-sm max-w-none
      prose-headings:font-mono prose-headings:text-xs prose-headings:text-[#00c8e0]
      prose-headings:uppercase prose-headings:tracking-widest prose-headings:font-semibold
      prose-p:text-[#8fa3c8] prose-li:text-[#8fa3c8]
      prose-a:text-[#00c8e0] prose-a:no-underline hover:prose-a:underline">
      <Content />
    </div>

    <p class="font-mono text-xs text-[#4a607f]">
      inspirado pelo <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer"
        class="text-[#00c8e0] hover:underline">/now movement</a>.
    </p>
  </article>
</BaseLayout>

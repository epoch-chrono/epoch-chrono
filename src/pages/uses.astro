---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../components/layout/BaseLayout.astro';

const entry = await getEntry('uses', 'index');
if (!entry) throw new Error('uses/index.md not found');
const { Content } = await render(entry);
---

<BaseLayout
  title="uses — epoch-chrono"
  description="Ferramentas, setup e stack que uso no dia a dia."
>
  <article class="space-y-10">
    <header class="space-y-1">
      <h1 class="text-2xl font-semibold tracking-tight text-[#e8edf7]">uses</h1>
      <p class="font-mono text-sm text-[#4a607f]">ferramentas e setup</p>
    </header>

    <div class="prose prose-invert prose-sm max-w-none
      prose-headings:font-mono prose-headings:text-xs prose-headings:text-[#00c8e0]
      prose-headings:uppercase prose-headings:tracking-widest prose-headings:font-semibold
      prose-p:text-[#8fa3c8] prose-li:text-[#8fa3c8]
      prose-a:text-[#00c8e0] prose-a:no-underline hover:prose-a:underline">
      <Content />
    </div>
  </article>
</BaseLayout>
